<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- SEO Meta Tags -->
    <meta name="description" content="Creative Group - The premier event company in Aurangabad. Explore our vibrant Summer Camps for kids, prestigious Pageants for kids and youngsters, and stunning Mall Décor & event activations.">
    <meta name="keywords" content="Creative Group, Event Company, Aurangabad, Summer Camp, Kids Pageant, Mall Decor, Event Activations, Kids Activities">
    <meta name="author" content="Creative Group">
    <title>Creative Group | Premier Events, Summer Camps & Pageants in Aurangabad</title>
    
    <!-- Open Graph for Social Sharing -->
    <meta property="og:title" content="Creative Group | Events, Summer Camps & Pageants">
    <meta property="og:description" content="Join Aurangabad's leading event company. Discover our Kids Summer Camps, Pageants, and Event Activations.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://creativegroup.example.com">
    <meta property="og:image" content="https://images.unsplash.com/photo-1540575467063-178a50c2df87?auto=format&fit=crop&q=80&w=1200">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Playfair+Display:ital,wght@0,600;1,600&display=swap" rel="stylesheet">
    
    <!-- External CSS Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Styles -->
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- Navigation -->
    <nav class="navbar" id="navbar">
        <div class="container nav-container">
            <a href="#" class="logo">
                <span class="logo-text">Creative<span class="highlight">Group</span></span>
            </a>
            <ul class="nav-links">
                <li><a href="#home">Home</a></li>
                <li><a href="#summer-camp">Summer Camp</a></li>
                <li><a href="#pageants">Pageants</a></li>
                <li><a href="#mall-decor">Mall Décor</a></li>
                <li><a href="#gallery">Gallery</a></li>
                <li><a href="#contact" class="btn btn-primary nav-cta">Register Now</a></li>
            </ul>
            <button class="mobile-toggle" aria-label="Toggle Navigation">
                <i class="fas fa-bars"></i>
            </button>
        </div>
    </nav>

    <!-- Hero Section -->
    <header id="home" class="hero">
        <div class="hero-bg"></div>
        <div class="container hero-content">
            <h1 class="hero-title">Crafting Unforgettable <br><span class="gradient-text">Experiences in Aurangabad</span></h1>
            <p class="hero-subtitle">From vibrant summer camps to prestigious pageants and breathtaking mall decors, Creative Group is your premier partner for extraordinary events.</p>
            <div class="hero-cta">
                <a href="#summer-camp" class="btn btn-primary">Our Offerings</a>
                <a href="#contact" class="btn btn-secondary">Get in Touch</a>
            </div>
        </div>
        <div class="scroll-indicator">
            <p>Scroll to Explore</p>
            <i class="fas fa-chevron-down"></i>
        </div>
    </header>

    <!-- Summer Camp Section -->
    <section id="summer-camp" class="section summer-camp-section">
        <div class="container flex-row">
            <div class="content-col">
                <div class="tag">Flagship Program</div>
                <h2 class="section-title">Kids <span class="highlight">Summer Camp</span></h2>
                <p class="section-text">Ignite your child's passion over the holidays with Aurangabad's most vibrant summer camp! A perfect blend of learning, fun, and personality development designed to bring out the bright spark in every kid.</p>
                <ul class="feature-list">
                    <li><i class="fas fa-swimmer"></i> Swimming & Water Sports</li>
                    <li><i class="fas fa-horse"></i> Horse Riding Adventures</li>
                    <li><i class="fas fa-music"></i> Dance & Performing Arts</li>
                    <li><i class="fas fa-palette"></i> Creative Arts & Crafts</li>
                    <li><i class="fas fa-brain"></i> Personality Development</li>
                </ul>
                <a href="#contact" class="btn btn-primary mt-4">Register for Camp</a>
            </div>
            <div class="image-col">
                <div class="image-wrapper glass-panel">
                    <img src="https://images.unsplash.com/photo-1511895426328-dc8714191300?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Kids playing at summer camp" loading="lazy">
                    <div class="floating-badge badge-1">
                        <span class="number">500+</span>
                        <span class="text">Happy Kids</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Pageants Section -->
    <section id="pageants" class="section pageants-section bg-dark">
        <div class="container flex-row row-reverse">
            <div class="content-col">
                <div class="tag tag-light">Glamour & Confidence</div>
                <h2 class="section-title text-light">Pageants for <span class="highlight-gold">Kids & Youngsters</span></h2>
                <p class="section-text text-light-muted">Step into the spotlight. Our professionally managed pageants are designed to boost self-esteem, refine talent, and offer a platform for young stars to shine brighter than ever.</p>
                <div class="stats-grid">
                    <div class="stat-item">
                        <i class="fas fa-crown"></i>
                        <h4>Grooming</h4>
                        <p>Expert mentoring</p>
                    </div>
                    <div class="stat-item">
                        <i class="fas fa-camera"></i>
                        <h4>Photoshoots</h4>
                        <p>Professional portfolios</p>
                    </div>
                    <div class="stat-item">
                        <i class="fas fa-star"></i>
                        <h4>Finale</h4>
                        <p>Grand stage events</p>
                    </div>
                </div>
                <a href="#contact" class="btn btn-gold mt-4">Audition Info</a>
            </div>
            <div class="image-col">
                <div class="image-wrapper glass-panel dark-glass">
                    <img src="https://images.unsplash.com/photo-1560087705-4c6e94e50eb1?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Children on a fashion runway" loading="lazy">
                </div>
            </div>
        </div>
    </section>

    <!-- Mall Decor & Activations Section -->
    <section id="mall-decor" class="section mall-decor-section">
        <div class="container flex-row">
            <div class="content-col">
                <div class="tag">Corporate & Retail</div>
                <h2 class="section-title">Mall Décor & <br><span class="highlight">Event Activations</span></h2>
                <p class="section-text">Transforming commercial spaces into captivating environments. We specialize in thematic mall decorations, festive makeovers, and brand activations that draw crowds and leave lasting impressions.</p>
                <div class="service-cards">
                    <div class="card">
                        <i class="fas fa-gift"></i>
                        <h3>Festive Decor</h3>
                        <p>Diwali, Christmas, & celebrations</p>
                    </div>
                    <div class="card">
                        <i class="fas fa-bullhorn"></i>
                        <h3>Brand Activations</h3>
                        <p>Product launches & promos</p>
                    </div>
                </div>
                <a href="#contact" class="btn btn-outline mt-4">Discuss a Project</a>
            </div>
            <div class="image-col">
                <div class="image-wrapper glass-panel">
                    <img src="https://images.unsplash.com/photo-1470229722913-7c090be31d66?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Decorated mall interior for events" loading="lazy">
                </div>
            </div>
        </div>
    </section>

    <!-- Gallery Section -->
    <section id="gallery" class="section gallery-section bg-light">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="section-title">Captured <span class="highlight">Moments</span></h2>
                <p class="section-text mx-auto">A glimpse into the joy, energy, and spectacular events orchestrated by Creative Group.</p>
            </div>
            <div class="gallery-grid">
                <div class="gallery-item item-wide"><img src="https://images.unsplash.com/photo-1502086223501-7ea6ecd79368?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Kids doing art" loading="lazy"><div class="overlay"><h4>Creative Arts</h4></div></div>
                <div class="gallery-item"><img src="https://images.unsplash.com/photo-1514525253161-7a46d19cd819?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Party context" loading="lazy"><div class="overlay"><h4>Celebrations</h4></div></div>
                <div class="gallery-item"><img src="https://images.unsplash.com/photo-1540324155974-7523202daa3f?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Runway lights" loading="lazy"><div class="overlay"><h4>Pageant Lights</h4></div></div>
                <div class="gallery-item"><img src="https://images.unsplash.com/photo-1505373877841-8d25f7d46678?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Festive setup" loading="lazy"><div class="overlay"><h4>Mall Setup</h4></div></div>
                <div class="gallery-item item-tall"><img src="https://images.unsplash.com/photo-1534447677768-be436bb09401?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Kids exploring" loading="lazy"><div class="overlay"><h4>Summer Adventures</h4></div></div>
                <div class="gallery-item"><img src="https://images.unsplash.com/photo-1522858102434-c7ad1ce10a1d?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" alt="Dance performance" loading="lazy"><div class="overlay"><h4>Dance Sessions</h4></div></div>
            </div>
        </div>
    </section>

    <!-- Testimonials Section -->
    <section class="section testimonials-section">
        <div class="container wrapper-testimonial">
            <h2 class="section-title text-center text-white mb-5">What People <span class="highlight-gold">Say</span></h2>
            <div class="testimonial-slider">
                <div class="testimonial-card">
                    <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                    <p class="quote">"The summer camp was incredibly organized. My daughter loved the horse riding and art classes. It brought out a completely new confident side in her!"</p>
                    <div class="author">
                        <img src="https://randomuser.me/api/portraits/women/44.jpg" alt="Priya S.">
                        <div>
                            <h5>Priya S.</h5>
                            <span>Parent</span>
                        </div>
                    </div>
                </div>
                <div class="testimonial-card">
                    <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                    <p class="quote">"Creative Group flawlessly executed our mall's Diwali decor. The footfall increased dramatically, and the visuals were stunning."</p>
                    <div class="author">
                        <img src="https://randomuser.me/api/portraits/men/32.jpg" alt="Rahul M.">
                        <div>
                            <h5>Rahul M.</h5>
                            <span>Mall Manager</span>
                        </div>
                    </div>
                </div>
                <div class="testimonial-card">
                    <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                    <p class="quote">"Winning the youth pageant gave me immense confidence. The grooming sessions were top-notch and truly transformative."</p>
                    <div class="author">
                        <img src="https://randomuser.me/api/portraits/women/68.jpg" alt="Neha K.">
                        <div>
                            <h5>Neha K.</h5>
                            <span>Pageant Winner</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact / Registration Form Section -->
    <section id="contact" class="section contact-section">
        <div class="container flex-row">
            <div class="contact-info">
                <h2 class="section-title">Ready to <br><span class="highlight">Join Us?</span></h2>
                <p class="section-text mb-4">Whether you want to register your child for the summer camp, audition for a pageant, or inquire about commercial event decor, we're here to help.</p>
                <div class="info-item">
                    <i class="fas fa-map-marker-alt"></i>
                    <div>
                        <h4>Location</h4>
                        <p>123 Creative Avenue, Aurangabad, Maharashtra 431001</p>
                    </div>
                </div>
                <div class="info-item">
                    <i class="fas fa-phone-alt"></i>
                    <div>
                        <h4>Call Us</h4>
                        <p>+91 98765 43210</p>
                    </div>
                </div>
                <div class="info-item">
                    <i class="fas fa-envelope"></i>
                    <div>
                        <h4>Email</h4>
                        <p>hello@creativegroup.com</p>
                    </div>
                </div>
                <div class="social-links mt-4">
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-facebook-f"></i></a>
                    <a href="#"><i class="fab fa-youtube"></i></a>
                </div>
            </div>
            <div class="contact-form-wrapper glass-panel">
                <form id="registration-form" class="contact-form">
                    <h3 class="form-title">Register / Inquire</h3>
                    <div class="form-group">
                        <label for="name">Full Name</label>
                        <input type="text" id="name" name="name" required placeholder="John Doe">
                    </div>
                    <div class="form-group">
                        <label for="phone">Phone Number</label>
                        <input type="tel" id="phone" name="phone" required placeholder="+91 XXXXX XXXXX">
                    </div>
                    <div class="form-group">
                        <label for="interest">I'm interested in</label>
                        <select id="interest" name="interest" required>
                            <option value="" disabled selected>Select an option</option>
                            <option value="summer_camp">Kids Summer Camp</option>
                            <option value="pageant">Pageants / Auditions</option>
                            <option value="decor">Mall Décor / Activations</option>
                            <option value="other">Other Inquiry</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="message">Message (Optional)</label>
                        <textarea id="message" name="message" rows="4" placeholder="How can we help you?"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Submit Details <i class="fas fa-paper-plane"></i></button>
                    <p class="form-success-msg" style="display:none; color: var(--success); margin-top: 10px; font-weight: 600;">Message sent successfully! We will contact you soon.</p>
                </form>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container text-center">
            <a href="#" class="logo mb-3 d-inline-block">
                <span class="logo-text">Creative<span class="highlight">Group</span></span>
            </a>
            <p class="footer-text">Bringing life to events in Aurangabad.</p>
            <div class="footer-links">
                <a href="#home">Home</a>
                <a href="#summer-camp">Summer Camp</a>
                <a href="#pageants">Pageants</a>
                <a href="#mall-decor">Décor</a>
            </div>
            <div class="copyright">
                &copy; <span id="year"></span> Creative Group Aurangabad. All Rights Reserved.
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="script.js"></script>
</body>
</html>
